# Copy to .env and fill in values

# App
APP_NAME=PIQBIT API
DEBUG=false
SECRET_KEY=change-me-to-a-random-64-char-secret

# Database (use asyncpg driver for async)
DATABASE_URL=postgresql+asyncpg://postegres:root@localhost:5432/piqbit

# Redis
REDIS_URL=redis://localhost:6379

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Bcrypt
BCRYPT_ROUNDS=12

# Brute-force
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# 2FA
TOTP_ISSUER=PIQBIT

# Email (SMTP — for verification & password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ouerghemmiemna1@gmail.com
SMTP_PASSWORD=yian juxe flpz ekob
EMAILS_FROM_EMAIL=ouerghemmiemna1@gmail.com
EMAILS_FROM_NAME=PIQBIT

# CORS (comma-separated for lists)
ALLOWED_ORIGINS=["http://localhost:3000"]
